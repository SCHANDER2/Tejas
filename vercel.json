{
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs"
    },
    "ai-service": {
      "root": "services/ai-service",
      "entrypoint": "app.main:app"
    },
    "backend": {
      "root": "services/backend",
      "entrypoint": "dist/app.js"
    }
  },
  "rewrites": [
    {
      "source": "/api/ai-service(/.*)?",
      "destination": {
        "type": "service",
        "service": "ai-service"
      }
    },
    {
      "source": "/api/backend(/.*)?",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "web"
      }
    }
  ]
}
